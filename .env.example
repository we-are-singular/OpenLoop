PUBLIC_SUPABASE_URL=your-supabase-url
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
RESEND_API_KEY=your-resend-key
# Public URL of this deployment (used in auth email redirects)
# Also set "Site URL" to this value in Supabase Dashboard > Authentication > URL Configuration
PUBLIC_SITE_URL=https://openloop.wearesingular.com

# For Supabase CLI (supabase db push / supabase link)
# Get from: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=your-personal-access-token