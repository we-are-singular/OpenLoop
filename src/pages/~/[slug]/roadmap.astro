---
import Layout from '../../../layouts/Layout.astro';
import OrgNav from '../../../components/OrgNav';
import OrgFooter from '../../../components/OrgFooter';
import RoadmapBoard from '../../../components/RoadmapBoard';
import { supabase, type Post } from '../../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

// Get org
const { data: organization } = await supabase
  .from('organizations')
  .select('id, name, slug')
  .eq('slug', slug)
  .single();

if (!organization) {
  return Astro.redirect('/404');
}

// Get posts by status
const { data: posts } = await supabase
  .from('posts')
  .select('*')
  .eq('organization_id', organization.id)
  .in('status', ['idea', 'planned', 'in_progress', 'completed'])
  .order('sort_order', { ascending: true });

const allPosts = posts || [];

const baseUrl = Astro.url.origin;
---

<Layout title={`${organization.name} Roadmap`}>
  <OrgNav client:load org={organization.slug} orgName={organization.name} currentPage="roadmap" />
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="text-center mb-12">
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-2">{organization.name} Roadmap</h1>
      <p class="text-gray-600">Ideas, planned features, and what's shipping</p>
    </div>

    <RoadmapBoard client:load initialPosts={allPosts as Post[]} orgSlug={slug || ''} baseUrl={baseUrl} />
  </div>
  <OrgFooter org={slug || ''} />
</Layout>
