---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Announcements | OpenLoop">
  <div id="app">
    <div class="flex items-center justify-center h-64">
      <div class="text-gray-500">Loading...</div>
    </div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    // Check session and refresh if needed
    async function getSupabase() {
      const stored = localStorage.getItem('sb_session');
      if (!stored) {
        window.location.href = '/admin/login?message=session_expired';
        return null;
      }
      try {
        let session = JSON.parse(stored);
        if (!session.access_token) {
          window.location.href = '/admin/login?message=session_expired';
          return null;
        }

        // Check if token is expired or about to expire (within 5 minutes)
        if (session.expires_at) {
          const expiresAt = session.expires_at * 1000;
          const now = Date.now();
          const fiveMinutes = 5 * 60 * 1000;

          if (now > expiresAt - fiveMinutes && session.refresh_token) {
            try {
              const refreshClient = createClient(supabaseUrl, supabaseAnonKey);
              const { data: refreshData, error: refreshError } = await refreshClient.auth.refreshSession({
                refresh_token: session.refresh_token
              });

              if (!refreshError && refreshData.session) {
                const newSession = {
                  access_token: refreshData.session.access_token,
                  refresh_token: refreshData.session.refresh_token,
                  user_id: refreshData.session.user.id,
                  expires_at: refreshData.session.expires_at
                };
                localStorage.setItem('sb_session', JSON.stringify(newSession));
                session = newSession;
              } else {
                localStorage.removeItem('sb_session');
                window.location.href = '/admin/login?message=session_expired';
                return null;
              }
            } catch {
              localStorage.removeItem('sb_session');
              window.location.href = '/admin/login?message=session_expired';
              return null;
            }
          }
        }

        return createClient(supabaseUrl, supabaseAnonKey, {
          global: {
            headers: { Authorization: `Bearer ${session.access_token}` }
          }
        });
      } catch {
        window.location.href = '/admin/login?message=session_expired';
        return null;
      }
    }

    // Handle API errors
    function handleApiError(error) {
      if (error?.status === 401 || error?.message?.includes('JWT')) {
        window.location.href = '/admin/login?message=session_expired';
        return;
      }
    }

    async function renderAnnouncements(org) {
      const supabase = await getSupabase();
      const app = document.getElementById('app');
      const orgId = org.id;
      const orgSlug = org.slug;

      async function load() {
        const { data: announcements } = await supabase
          .from('announcements')
          .select('*')
          .eq('organization_id', orgId)
          .order('created_at', { ascending: false });

        app.innerHTML = `
          <div>
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <h1 class="text-2xl font-bold text-gray-900">Announcements</h1>
                <a href="/~/${orgSlug}/announcements" target="_blank" class="flex items-center gap-1 text-sm text-gray-500 hover:text-indigo-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  See public
                </a>
              </div>
              <button id="add-btn" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700">
                Add Announcement
              </button>
            </div>

            <div id="form-container" class="hidden bg-white rounded-lg border p-6 mb-6">
              <h2 class="text-lg font-semibold mb-4">New Announcement</h2>
              <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                <input type="text" id="ann-title" class="w-full px-3 py-2 border rounded-lg" />
              </div>
              <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Content</label>
                <textarea id="ann-content" rows="4" class="w-full px-3 py-2 border rounded-lg"></textarea>
              </div>
              <div class="mb-4">
                <label class="flex items-center gap-2">
                  <input type="checkbox" id="ann-publish" class="rounded" />
                  <span class="text-sm font-medium text-gray-700">Publish immediately</span>
                </label>
              </div>
              <div class="flex gap-2">
                <button id="save-btn" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700">Save</button>
                <button id="cancel-btn" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Cancel</button>
              </div>
            </div>

            <div class="bg-white rounded-lg border overflow-hidden">
              <table class="w-full">
                <thead class="bg-gray-50 border-b">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y">
                  ${(!announcements || announcements.length === 0) ? `
                    <tr>
                      <td colspan="4" class="px-6 py-8 text-center text-gray-500">No announcements yet</td>
                    </tr>
                  ` : announcements.map(ann => `
                    <tr class="hover:bg-gray-50">
                      <td class="px-6 py-4">
                        <div class="font-medium text-gray-900">${ann.title}</div>
                        ${ann.content ? `<div class="text-sm text-gray-500 line-clamp-1">${ann.content}</div>` : ''}
                      </td>
                      <td class="px-6 py-4">
                        <span class="px-2 py-1 text-xs rounded-full ${ann.published_at ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-700'}">
                          ${ann.published_at ? 'Published' : 'Draft'}
                        </span>
                      </td>
                      <td class="px-6 py-4 text-gray-500 text-sm">${new Date(ann.created_at).toLocaleDateString()}</td>
                      <td class="px-6 py-4 text-right">
                        <button data-publish="${ann.id}" class="text-indigo-600 hover:text-indigo-800 text-sm mr-3">
                          ${ann.published_at ? 'Unpublish' : 'Publish'}
                        </button>
                        <button data-delete="${ann.id}" class="text-red-600 hover:text-red-800 text-sm">Delete</button>
                      </td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
          </div>
        `;

        // Event handlers
        app.querySelector('#add-btn')?.addEventListener('click', () => {
          app.querySelector('#form-container').classList.remove('hidden');
        });

        app.querySelector('#cancel-btn')?.addEventListener('click', () => {
          app.querySelector('#form-container').classList.add('hidden');
        });

        app.querySelector('#save-btn')?.addEventListener('click', async () => {
          const title = document.getElementById('ann-title').value;
          const content = document.getElementById('ann-content').value;
          const publish = document.getElementById('ann-publish').checked;

          await supabase.from('announcements').insert({
            organization_id: orgId,
            title,
            content,
            published_at: publish ? new Date().toISOString() : null
          });

          document.getElementById('ann-title').value = '';
          document.getElementById('ann-content').value = '';
          document.getElementById('ann-publish').checked = false;
          app.querySelector('#form-container').classList.add('hidden');
          window.showToast?.('Announcement created', 'success');
          load();
        });

        app.querySelectorAll('[data-publish]').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            const id = e.target.dataset.publish;
            const ann = announcements.find(a => a.id === id);
            await supabase.from('announcements').update({
              published_at: ann.published_at ? null : new Date().toISOString()
            }).eq('id', id);
            window.showToast?.(ann.published_at ? 'Unpublished' : 'Published', 'success');
            load();
          });
        });

        app.querySelectorAll('[data-delete]').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            if (!confirm('Delete this announcement?')) return;
            await supabase.from('announcements').delete().eq('id', e.target.dataset.delete);
            window.showToast?.('Announcement deleted', 'success');
            load();
          });
        });
      }

      load();
    }

    async function init() {
      const supabase = await getSupabase();
      if (!supabase) {
        window.location.href = '/admin/login';
        return;
      }

      // Get selected organization from localStorage
      let org = null;
      const selectedOrgId = localStorage.getItem('selected_org_id');

      if (selectedOrgId) {
        const { data } = await supabase
          .from('organizations')
          .select('id, slug')
          .eq('id', selectedOrgId)
          .single();
        org = data;
      }

      // Fallback: get first organization via user_organizations or legacy
      if (!org) {
        const { data: { user } } = await supabase.auth.getUser();
        if (user) {
          const { data: userOrgs } = await supabase
            .from('user_organizations')
            .select('organization_id, organizations(id, slug)')
            .eq('user_id', user.id)
            .limit(1);

          if (userOrgs && userOrgs.length > 0) {
            org = userOrgs[0].organizations;
            localStorage.setItem('selected_org_id', org.id);
          }
        }
      }

      // Legacy fallback
      if (!org) {
        const { data: orgs } = await supabase.from('organizations').select('id, slug').limit(1);
        org = orgs?.[0];
      }

      const app = document.getElementById('app');
      if (!org) {
        app.innerHTML = `
          <div class="text-center py-12">
            <h1 class="text-2xl font-bold text-gray-900 mb-4">No Organization Found</h1>
            <p class="text-gray-600 mb-4">Please set up your organization first.</p>
            <a href="/admin/settings" class="text-indigo-600 hover:text-indigo-800">Go to Settings</a>
          </div>
        `;
        return;
      }

      renderAnnouncements(org);
    }

    init();
  </script>
</AdminLayout>
